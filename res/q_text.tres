[sub_resource type="GDScript" id="GDScript_e2vm2"]
script/source = "extends Resource

@export_multiline var question_texts: Array[String]
"

[resource]
script = SubResource("GDScript_e2vm2")
question_texts = Array[String](["A ball is dropped from rest onto a surface with coefficient of restitution %.4f, from which it bounces up to a maximum height of %.4f. What was the initial height of the ball?", "A ball at rest is dropped from a height of %.4f onto a surface with coefficient of restitution %.4f. What is the maximum height of the ball on its first bounce?", "A ball at rest is dropped from a height of %.4f onto the bowling alley and reaches a maximum height of %.4f on its first bounce. What is the coefficient of restitution of the bowling alley?", "A ball is to be thrown from the ground over a %.4fm tall wall %.4fm away in order to hit a pin %.4fm away. What angle and power allow the ball to hit the pin?", "A ball is to be thrown from the ground with a speed of %.4fm/s at an angle of %.2f to go over a barrier. How long will the ball be in the air for?", "A ball is to be thrown from the ground with a speed of %.4fm/s to go over a barrier %.2fm meters tall that's %.2fm away. How long will the ball be in the air for?", "A ball is to be thrown through a small gap %.4fm away horizontally, with initial velocity %.4fm/s at an angle of %.2f to the horizontal. What height is the ball when it passes between the barriers?", "A ball is to be thrown through a small gap %.4fm off the ground, with initial velocity %.4fm/s at an angle of %.2f to the horizontal. What horizontal distance should the ball be thrown from in order to pass through the gap?", "A bowling ball rolls at %.4fm/s into a stationary pin with mass %.4fkg. The ball's velocity after the collision is %.4fm/s, and the pin's velocity is %.4fm/s. What is the mass of the ball? ", "A bowling ball with mass %.4fkg rolls at %.4fm/s into a stationary pin. The ball's velocity after the collision is %.4fm/s, and the pin's velocity is %.4fm/s. What is the mass of the pin? ", "A bowling ball with mass %.4fkg rolls into a stationary pin with mass %.4fkg. The ball's velocity after the collision is %.4fm/s, and the pin's velocity is %.4fm/s. What is the speed of the ball before the collision?", "A bowling ball with mass %.4fkg rolls at %.4fm/s into a stationary pin with mass %.4fkg. The pin's velocity after colliding is %.4fm/s. What is the speed of the ball after the collision?", "A bowling ball with mass %.4fkg rolls at %.4fm/s into a stationary pin with mass %.4fkg. The ball's velocity after colliding is %.4fm/s. What is the speed of the pin after the collision?"])
